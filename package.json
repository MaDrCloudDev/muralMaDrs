{
  "name": "mural-madrs",
  "version": "3.0.0",
  "description": "Community mural discovery platform rebuilt with Bun, Hono, and TypeScript",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/dev-server.ts",
    "dev:full": "concurrently \"bun run build:css:watch\" \"bun --watch src/dev-server.ts\"",
    "start": "bun src/dev-server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "build:css": "mkdir -p /tmp/bun-tmp /tmp/bun-install && BUN_TMPDIR=/tmp/bun-tmp BUN_INSTALL=/tmp/bun-install tailwindcss -i ./public/stylesheets/input.css -o ./public/stylesheets/output.css --minify",
    "build:css:watch": "mkdir -p /tmp/bun-tmp /tmp/bun-install && BUN_TMPDIR=/tmp/bun-tmp BUN_INSTALL=/tmp/bun-install tailwindcss -i ./public/stylesheets/input.css -o ./public/stylesheets/output.css --watch"
  },
  "keywords": [
    "hono",
    "bun",
    "typescript",
    "mongodb",
    "murals"
  ],
  "license": "ISC",
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "cloudinary": "^2.5.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.13",
    "mongoose": "^8.9.5",
    "passport-local-mongoose": "^8.0.0",
    "sanitize-html": "^2.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@types/node": "^22.10.2",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2"
  }
}
