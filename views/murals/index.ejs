<% layout('layouts/boilerplate')%>
<div class="page-transition">
	<div id="mymap"></div>
	<div class="muralscontainer container">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1 class="display-4 fw-bold text-dark">Discover Murals</h1>
			<a href="/murals/new" class="btn btn-primary">
				<i class="fas fa-plus"></i> Add New Mural
			</a>
		</div>
		
		<% if (murals.length === 0) { %>
			<div class="text-center py-5">
				<i class="fas fa-paint-brush fa-4x text-muted mb-3"></i>
				<h3 class="text-muted">No murals yet</h3>
				<p class="text-muted">Be the first to share a beautiful mural!</p>
				<a href="/murals/new" class="btn btn-primary">Add the First Mural</a>
			</div>
		<% } else { %>
			<div class="murals-grid">
				<% for (let mural of murals){%>
				<div class="card h-100">
					<div class="position-relative">
						<%if(mural.images.length) {%>
						<img
							class="card-img-top"
							alt="<%= mural.title %>"
							src="<%=mural.images[0].url%>"
							loading="lazy" />
						<% }else {%>
						<img
							class="card-img-top"
							alt="Default mural image"
							src="https://images.unsplash.com/photo-1541961017774-22349e4a1262?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
							loading="lazy" />
						<% } %>
						<!-- <div class="position-absolute top-0 end-0 m-2">
							<span class="badge bg-dark bg-opacity-75">
								<i class="fas fa-images"></i> <%= mural.images.length %>
							</span>
						</div> -->
					</div>
					<div class="card-body d-flex flex-column">
						<h5 class="card-title text-truncate" title="<%= mural.title %>">
							<%= mural.title %>
						</h5>
						<p class="card-text text-muted mb-2">
							<i class="fas fa-user"></i> By <%= mural.artist %>
						</p>
						<p class="card-text flex-grow-1">
							<%= mural.description.length > 100 ? mural.description.substring(0, 100) + '...' : mural.description %>
						</p>
						<div class="mt-auto">
							<p class="card-text mb-3">
								<small class="text-muted">
									<i class="fas fa-map-marker-alt"></i> <%= mural.location %>
								</small>
							</p>
							<a
								class="btn btn-primary w-100"
								href="/murals/<%=mural._id%>"
								>View Details</a>
						</div>
					</div>
				</div>
				<% }%>
			</div>
		<% } %>
	</div>
</div>
<script>
	const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
	const murals = { features: <%- JSON.stringify(murals) %>}

	// filter murals by state using ejs and javascript
	let selectedState = 'Arizona'

	const state = { features: <%- JSON.stringify(murals.filter(mural => mural.location.includes('arizona'))) %>}
</script>

<script src="/javascripts/clusterMap.js"></script>
