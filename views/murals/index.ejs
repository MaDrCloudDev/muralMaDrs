<% layout('layouts/boilerplate')%>
<div class="animate-fadeInUp">
	<div id="mymap"></div>
	<div class="mt-8">
		<div
			class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
			<h1 class="text-4xl md:text-5xl font-bold text-gradient">
				Discover Murals
			</h1>
			<a
				href="/murals/new"
				class="inline-flex items-center gap-2 bg-gradient-primary text-white px-6 py-3 rounded-xl font-semibold hover:scale-105 hover:shadow-lg transition-all duration-300">
				<i class="fas fa-plus"></i> Add New Mural
			</a>
		</div>

		<% if (murals.length === 0) { %>
		<div class="text-center py-16">
			<i class="fas fa-paint-brush text-6xl text-muted mb-6"></i>
			<h3 class="text-2xl font-semibold text-muted-foreground mb-4">
				No murals yet
			</h3>
			<p class="text-muted-foreground mb-8">
				Be the first to share a beautiful mural!
			</p>
			<a
				href="/murals/new"
				class="inline-flex items-center gap-2 bg-gradient-primary text-white px-8 py-4 rounded-xl font-semibold hover:scale-105 hover:shadow-lg transition-all duration-300">
				Add the First Mural
			</a>
		</div>
		<% } else { %>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<% for (let mural of murals){%>
			<div
				class="bg-card rounded-xl overflow-hidden shadow-lg hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group flex flex-col">
				<div class="relative overflow-hidden">
					<%if(mural.images.length) {%>
					<img
						class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300"
						alt="<%= mural.title %>"
						src="<%=mural.images[0].url%>"
						loading="lazy" />
					<% }else {%>
					<img
						class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300"
						alt="Default mural image"
						src="https://images.unsplash.com/photo-1541961017774-22349e4a1262?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
						loading="lazy" />
					<% } %>
					<div
						class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
				</div>
				<div class="p-6 flex flex-col justify-between min-h-[280px]">
					<div>
						<h5
							class="text-xl font-semibold text-foreground mb-3 truncate"
							title="<%= mural.title %>">
							<%= mural.title %>
						</h5>
						<p
							class="text-muted-foreground mb-3 flex items-center gap-2">
							<i class="fas fa-user text-sm"></i> By <%= mural.artist
							%>
						</p>
						<p class="text-muted-foreground mb-4 line-clamp-3">
							<%= mural.description.length > 100 ?
							mural.description.substring(0, 100) + '...' :
							mural.description %>
						</p>
						<p
							class="text-sm text-muted-foreground mb-4 flex items-center gap-2">
							<i class="fas fa-map-marker-alt text-primary"></i> <%=
							mural.location %>
						</p>
					</div>
					<a
						class="w-full inline-flex items-center justify-center bg-gradient-primary text-white px-4 py-3 rounded-lg font-medium hover:scale-105 hover:shadow-lg transition-all duration-300"
						href="/murals/<%=mural._id%>"
						>View Details</a
					>
				</div>
			</div>
			<% }%>
		</div>
		<% } %>
	</div>
</div>
<script>
	const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
	const murals = { features: <%- JSON.stringify(murals) %>}

	// filter murals by state using ejs and javascript
	let selectedState = 'Arizona'

	const state = { features: <%- JSON.stringify(murals.filter(mural => mural.location.includes('arizona'))) %>}
</script>

<script src="/javascripts/clusterMap.js"></script>
