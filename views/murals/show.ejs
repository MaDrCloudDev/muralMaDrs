<% layout('layouts/boilerplate')%>
<link
	rel="stylesheet"
	href="/stylesheets/stars.css" />
<div class="animate-fadeInUp">
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
		<div class="lg:col-span-2">
			<div class="bg-card rounded-2xl overflow-hidden shadow-xl mb-8">
				<% if(mural.images.length > 0) { %>
				<div class="relative">
					<div class="carousel-container">
						<% mural.images.forEach((img, i) => { %>
						<div
							class="carousel-slide <%= i === 0 ? 'active' : 'hidden' %>"
							data-slide="<%= i %>">
							<img
								src="<%= img.url%>"
								class="w-full h-96 md:h-[500px] object-cover"
								alt="<%= mural.title %> - Image <%= i + 1 %>"
								loading="<%= i === 0 ? 'eager' : 'lazy' %>" />
						</div>
						<% }) %>
					</div>
					<% if(mural.images.length > 1) {%>
					<button
						id="prevSlideBtn"
						class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-3 rounded-full backdrop-blur-sm transition-all duration-300">
						<i class="fas fa-chevron-left"></i>
					</button>
					<button
						id="nextSlideBtn"
						class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-3 rounded-full backdrop-blur-sm transition-all duration-300">
						<i class="fas fa-chevron-right"></i>
					</button>
					<div
						class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
						<% mural.images.forEach((img, i) => { %>
						<button
							class="w-3 h-3 rounded-full bg-white/50 hover:bg-white/80 transition-all duration-300 <%= i === 0 ? 'bg-white' : '' %> slide-indicator"
							data-slide="<%= i %>"
							data-indicator="<%= i %>"></button>
						<% }) %>
					</div>
					<% } %>
				</div>
				<% } else { %>
				<div
					class="h-96 flex flex-col items-center justify-center bg-gray-100 dark:bg-gray-800">
					<i
						class="fas fa-image text-6xl text-muted-foreground mb-4"></i>
					<p class="text-muted-foreground text-lg">
						No images available
					</p>
				</div>
				<% } %>
			</div>

			<div class="bg-card rounded-2xl shadow-xl overflow-hidden">
				<div class="p-6 border-b border-border">
					<div
						class="flex flex-col lg:flex-row justify-between items-start gap-4">
						<div class="flex-1">
							<h1
								class="text-3xl md:text-4xl font-bold text-foreground mb-4">
								<%= mural.title%>
							</h1>
							<div class="flex flex-wrap gap-3">
								<span
									class="inline-flex items-center gap-2 bg-primary/10 text-primary px-3 py-2 rounded-full text-sm font-medium">
									<i class="fas fa-user"></i> <%= mural.artist%>
								</span>
								<span
									class="inline-flex items-center gap-2 bg-secondary/10 text-secondary px-3 py-2 rounded-full text-sm font-medium">
									<i class="fas fa-map-marker-alt"></i> <%=
									mural.location%>
								</span>
								<span
									class="inline-flex items-center gap-2 bg-accent/10 text-accent px-3 py-2 rounded-full text-sm font-medium">
									<i class="fas fa-user-plus"></i> <%=
									mural.author.username%>
								</span>
							</div>
						</div>
						<% if( currentUser &&
						mural.author.equals(currentUser._id)) {%>
						<div class="flex flex-col sm:flex-row gap-3 mt-4 lg:mt-0">
							<a
								class="inline-flex items-center justify-center gap-2 bg-primary/10 hover:bg-primary/20 text-primary px-4 py-3 rounded-lg font-medium transition-all duration-300 min-w-[120px]"
								href="/murals/<%=mural._id%>/edit">
								<i class="fas fa-edit"></i> Edit
							</a>
							<button
								type="button"
								id="deleteButton"
								class="inline-flex items-center justify-center gap-2 bg-red-50 hover:bg-red-100 text-red-600 px-4 py-3 rounded-lg font-medium transition-all duration-300 min-w-[120px]">
								<i class="fas fa-trash"></i> Delete
							</button>
						</div>
						<% } %>
					</div>
				</div>
				<div class="p-6">
					<p class="text-lg text-muted-foreground leading-relaxed">
						<%= mural.description%>
					</p>
				</div>
			</div>
		</div>

		<div class="space-y-8">
			<div class="bg-card rounded-2xl shadow-xl overflow-hidden">
				<div class="p-6 border-b border-border">
					<h5
						class="text-xl font-semibold text-foreground flex items-center gap-2">
						<i class="fas fa-map-marked-alt text-primary"></i>
						Location
					</h5>
				</div>
				<div class="p-0">
					<div
						id="map"
						class="h-64 w-full"></div>
				</div>
			</div>

			<div class="space-y-6">
				<% if(currentUser){ %>
				<div class="bg-card rounded-2xl shadow-xl overflow-hidden">
					<div class="p-6 border-b border-border">
						<h5
							class="text-xl font-semibold text-foreground flex items-center gap-2">
							<i class="fas fa-star text-primary"></i> Leave a Review
						</h5>
					</div>
					<div class="p-6">
						<form
							action="/murals/<%=mural._id%>/reviews"
							method="POST"
							class="validated-form space-y-4"
							novalidate>
							<div>
								<label
									class="block text-sm font-semibold text-foreground mb-3"
									>Rating</label
								>
								<fieldset class="starability-basic">
									<input
										type="radio"
										id="no-rate"
										class="input-no-rate"
										name="review[rating]"
										value="1"
										checked
										aria-label="No rating." />
									<input
										type="radio"
										id="first-rate1"
										name="review[rating]"
										value="1" />
									<label
										for="first-rate1"
										title="Terrible"
										>1 star</label
									>
									<input
										type="radio"
										id="first-rate2"
										name="review[rating]"
										value="2" />
									<label
										for="first-rate2"
										title="Not good"
										>2 stars</label
									>
									<input
										type="radio"
										id="first-rate3"
										name="review[rating]"
										value="3" />
									<label
										for="first-rate3"
										title="Average"
										>3 stars</label
									>
									<input
										type="radio"
										id="first-rate4"
										name="review[rating]"
										value="4" />
									<label
										for="first-rate4"
										title="Very good"
										>4 stars</label
									>
									<input
										type="radio"
										id="first-rate5"
										name="review[rating]"
										value="5" />
									<label
										for="first-rate5"
										title="Amazing"
										>5 stars</label
									>
								</fieldset>
							</div>
							<div>
								<label
									class="block text-sm font-semibold text-foreground mb-2"
									for="body"
									>Your Review</label
								>
								<textarea
									class="w-full px-4 py-3 bg-input border-2 border-border rounded-lg text-foreground placeholder-muted-foreground focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-300 resize-none"
									name="review[body]"
									id="body"
									rows="4"
									placeholder="Share your thoughts about this mural..."
									required></textarea>
								<div
									class="valid-feedback text-green-600 text-sm mt-1 hidden">
									Looks good!
								</div>
								<div
									class="invalid-feedback text-red-600 text-sm mt-1 hidden">
									Please write a review.
								</div>
							</div>
							<button
								type="submit"
								class="w-full bg-gradient-primary text-white py-3 rounded-lg font-semibold hover:scale-105 hover:shadow-lg transition-all duration-300 flex items-center justify-center gap-2">
								<i class="fas fa-paper-plane"></i> Submit Review
							</button>
						</form>
					</div>
				</div>
				<% } %> <% if(mural.reviews.length > 0) { %>
				<div class="bg-card rounded-2xl shadow-xl overflow-hidden">
					<div class="p-6 border-b border-border">
						<h5
							class="text-xl font-semibold text-foreground flex items-center gap-2">
							<i class="fas fa-comments text-primary"></i> Reviews
							<span
								class="bg-secondary/10 text-secondary px-2 py-1 rounded-full text-sm font-medium"
								><%= mural.reviews.length %></span
							>
						</h5>
					</div>
					<div class="p-6 space-y-6">
						<% for(let review of mural.reviews) { %>
						<div
							class="<%= mural.reviews.indexOf(review) !== mural.reviews.length - 1 ? 'border-b border-border pb-6' : '' %>">
							<div class="flex justify-between items-start mb-3">
								<div>
									<h6 class="font-semibold text-foreground mb-1">
										<%= review.author.username%>
									</h6>
									<p
										class="starability-result text-sm"
										data-rating="<%=review.rating%>">
										Rated: <%= review.rating %> stars
									</p>
								</div>
								<% if( currentUser &&
								review.author.equals(currentUser._id)) {%>
								<form
									action="/murals/<%=mural._id%>/reviews/<%=review._id%>?_method=DELETE"
									method="POST"
									class="inline">
									<button
										type="submit"
										class="text-red-500 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition-all duration-300"
										onclick="return confirm('Are you sure you want to delete this review?')">
										<i class="fas fa-trash-alt"></i>
									</button>
								</form>
								<% } %>
							</div>
							<p class="text-muted-foreground leading-relaxed">
								<%= review.body %>
							</p>
						</div>
						<% } %>
					</div>
				</div>
				<% } else { %>
				<div class="bg-card rounded-2xl shadow-xl">
					<div class="p-8 text-center">
						<i
							class="fas fa-comments text-6xl text-muted-foreground mb-4"></i>
						<h6
							class="text-lg font-semibold text-muted-foreground mb-2">
							No reviews yet
						</h6>
						<p class="text-muted-foreground">
							Be the first to share your thoughts!
						</p>
					</div>
				</div>
				<% } %>
			</div>
		</div>
	</div>

	<% if( currentUser && mural.author.equals(currentUser._id)) {%>
	<div
		id="deleteModal"
		class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[9999] hidden items-center justify-center p-4"
		style="display: none">
		<div
			class="bg-card rounded-2xl shadow-2xl max-w-md w-full animate-fadeInUp">
			<div class="p-6 border-b border-border">
				<div class="flex items-center justify-between">
					<h5 class="text-xl font-semibold text-foreground">
						Delete Mural
					</h5>
					<button
						type="button"
						id="closeModalBtn"
						class="text-muted-foreground hover:text-foreground transition-colors">
						<i class="fas fa-times text-xl"></i>
					</button>
				</div>
			</div>
			<div class="p-6">
				<p class="text-foreground mb-2">
					Are you sure you want to delete "<strong
						><%= mural.title %></strong
					>"?
				</p>
				<p class="text-muted-foreground text-sm">
					This action cannot be undone.
				</p>
			</div>
			<div class="p-6 border-t border-border flex gap-3 justify-end">
				<button
					type="button"
					id="cancelDeleteBtn"
					class="px-4 py-2 text-muted-foreground hover:text-foreground hover:bg-border/50 rounded-lg transition-all duration-300">
					Cancel
				</button>
				<form
					action="/murals/<%=mural._id%>?_method=DELETE"
					method="POST"
					class="inline">
					<button
						type="submit"
						class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition-all duration-300">
						Delete Mural
					</button>
				</form>
			</div>
		</div>
	</div>
	<% } %>
</div>

<script>
	const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
	const mural = <%- JSON.stringify(mural) %>;

	let currentSlide = 0;
	const totalSlides = <%= mural.images.length %>;

	function showSlide(index) {
		const slides = document.querySelectorAll('.carousel-slide');
		const indicators = document.querySelectorAll('[data-indicator]');

		slides.forEach((slide, i) => {
			if (i === index) {
				slide.classList.remove('hidden');
				slide.classList.add('active');
			} else {
				slide.classList.add('hidden');
				slide.classList.remove('active');
			}
		});

		indicators.forEach((indicator, i) => {
			if (i === index) {
				indicator.classList.add('bg-white');
				indicator.classList.remove('bg-white/50');
			} else {
				indicator.classList.remove('bg-white');
				indicator.classList.add('bg-white/50');
			}
		});
	}

	function nextSlide() {
		currentSlide = (currentSlide + 1) % totalSlides;
		showSlide(currentSlide);
	}

	function previousSlide() {
		currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
		showSlide(currentSlide);
	}

	function goToSlide(index) {
		currentSlide = index;
		showSlide(currentSlide);
	}

	document.addEventListener('DOMContentLoaded', function() {
		const deleteButton = document.getElementById('deleteButton');
		if (deleteButton) {
			deleteButton.addEventListener('click', function() {
				console.log('Delete button clicked!');
				openDeleteModal();
			});
		}

		const closeModalBtn = document.getElementById('closeModalBtn');
		const cancelDeleteBtn = document.getElementById('cancelDeleteBtn');

		if (closeModalBtn) {
			closeModalBtn.addEventListener('click', closeDeleteModal);
		}

		if (cancelDeleteBtn) {
			cancelDeleteBtn.addEventListener('click', closeDeleteModal);
		}

		const modal = document.getElementById('deleteModal');
		if (modal) {
			modal.addEventListener('click', function(e) {
				if (e.target === this) {
					closeDeleteModal();
				}
			});
		}

		const prevBtn = document.getElementById('prevSlideBtn');
		const nextBtn = document.getElementById('nextSlideBtn');

		if (prevBtn) {
			prevBtn.addEventListener('click', previousSlide);
		}

		if (nextBtn) {
			nextBtn.addEventListener('click', nextSlide);
		}
		const indicators = document.querySelectorAll('.slide-indicator');
		indicators.forEach(indicator => {
			indicator.addEventListener('click', function() {
				const slideIndex = parseInt(this.dataset.slide);
				goToSlide(slideIndex);
			});
		});

		document.addEventListener('keydown', function(e) {
			if (totalSlides > 1) {
				if (e.key === 'ArrowLeft') {
					previousSlide();
				} else if (e.key === 'ArrowRight') {
					nextSlide();
				}
			}

			if (e.key === 'Escape') {
				closeDeleteModal();
			}
		});
	});

	function openDeleteModal() {
		console.log('Opening delete modal...');
		const modal = document.getElementById('deleteModal');
		if (modal) {
			modal.style.display = 'flex';
			modal.classList.remove('hidden');
			modal.classList.add('flex');
			document.body.style.overflow = 'hidden';
			console.log('Modal opened successfully');
		} else {
			console.error('Modal not found!');
		}
	}

	function closeDeleteModal() {
		console.log('Closing delete modal...');
		const modal = document.getElementById('deleteModal');
		if (modal) {
			modal.style.display = 'none';
			modal.classList.add('hidden');
			modal.classList.remove('flex');
			document.body.style.overflow = '';
		}
	}
</script>

<script src="/javascripts/showPageMap.js"></script>
