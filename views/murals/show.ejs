<% layout('layouts/boilerplate')%>
<link rel="stylesheet" href="/stylesheets/stars.css" />
<div class="page-transition">
	<div class="container-fluid">
		<div class="row">
			<div class="col-lg-8">
				<!-- Image Carousel -->
				<div class="mural-carousel-container mb-4">
					<% if(mural.images.length > 0) { %>
					<div id="muralCarousel" class="carousel slide" data-bs-ride="carousel">
						<div class="carousel-inner">
							<% mural.images.forEach((img, i) => { %>
							<div class="carousel-item <%= i === 0 ? 'active' : ''%>">
								<img
									src="<%= img.url%>"
									class="d-block w-100 mural-image"
									alt="<%= mural.title %> - Image <%= i + 1 %>"
									loading="<%= i === 0 ? 'eager' : 'lazy' %>" />
							</div>
							<% }) %>
						</div>
						<% if(mural.images.length > 1) {%>
						<button class="carousel-control-prev" type="button" data-bs-target="#muralCarousel" data-bs-slide="prev">
							<span class="carousel-control-prev-icon" aria-hidden="true"></span>
							<span class="visually-hidden">Previous</span>
						</button>
						<button class="carousel-control-next" type="button" data-bs-target="#muralCarousel" data-bs-slide="next">
							<span class="carousel-control-next-icon" aria-hidden="true"></span>
							<span class="visually-hidden">Next</span>
						</button>
						<div class="carousel-indicators">
							<% mural.images.forEach((img, i) => { %>
							<button type="button" data-bs-target="#muralCarousel" data-bs-slide-to="<%= i %>" 
								<%= i === 0 ? 'class="active" aria-current="true"' : '' %> 
								aria-label="Slide <%= i + 1 %>"></button>
							<% }) %>
						</div>
						<% } %>
					</div>
					<% } else { %>
					<div class="no-image-placeholder">
						<i class="fas fa-image fa-4x text-muted"></i>
						<p class="text-muted mt-3">No images available</p>
					</div>
					<% } %>
				</div>

				<!-- Mural Details Card -->
				<div class="card mural-details-card mb-4">
					<div class="card-header bg-transparent">
						<div class="d-flex justify-content-between align-items-start">
							<div>
								<h1 class="card-title h2 mb-2"><%= mural.title%></h1>
								<div class="mural-meta">
									<span class="badge bg-primary me-2">
										<i class="fas fa-user"></i>Artist: <%= mural.artist%>
									</span>
									<span class="badge bg-secondary me-2">
										<i class="fas fa-map-marker-alt"></i>Location: <%= mural.location%>
									</span>
									<span class="badge bg-info">
										<i class="fas fa-user-plus"></i> Uploader: <%= mural.author.username%>
									</span>
								</div>
							</div>
							<% if( currentUser && mural.author.equals(currentUser._id)) {%>
							<div class="btn-group">
								<a class="btn btn-outline-primary" href="/murals/<%=mural._id%>/edit">
									<i class="fas fa-edit"></i> Edit
								</a>
								<button type="button" class="btn btn-outline-danger" data-toggle="modal" data-target="#deleteModal">
									<i class="fas fa-trash"></i> Delete
								</button>
							</div>
							<% } %>
						</div>
					</div>
					<div class="card-body">
						<p class="card-text lead"><%= mural.description%></p>
					</div>
				</div>
			</div>
			
			<div class="col-lg-4">
				<!-- Map Section -->
				<div class="card mb-4">
					<div class="card-header">
						<h5 class="mb-0"><i class="fas fa-map-marked-alt"></i> Location</h5>
					</div>
					<div class="card-body p-0">
						<div id="map" class="mural-map"></div>
					</div>
				</div>

				<!-- Reviews Section -->
				<div class="reviews-section">
					<% if(currentUser){ %>
					<div class="card mb-4">
						<div class="card-header">
							<h5 class="mb-0"><i class="fas fa-star"></i> Leave a Review</h5>
						</div>
						<div class="card-body">
							<form action="/murals/<%=mural._id%>/reviews" method="POST" class="validated-form" novalidate>
								<div class="mb-3">
									<label class="form-label">Rating</label>
									<fieldset class="starability-basic">
										<input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
										<input type="radio" id="first-rate1" name="review[rating]" value="1" />
										<label for="first-rate1" title="Terrible">1 star</label>
										<input type="radio" id="first-rate2" name="review[rating]" value="2" />
										<label for="first-rate2" title="Not good">2 stars</label>
										<input type="radio" id="first-rate3" name="review[rating]" value="3" />
										<label for="first-rate3" title="Average">3 stars</label>
										<input type="radio" id="first-rate4" name="review[rating]" value="4" />
										<label for="first-rate4" title="Very good">4 stars</label>
										<input type="radio" id="first-rate5" name="review[rating]" value="5" />
										<label for="first-rate5" title="Amazing">5 stars</label>
									</fieldset>
								</div>
								<div class="mb-3">
									<label class="form-label" for="body">Your Review</label>
									<textarea class="form-control" name="review[body]" id="body" rows="4" placeholder="Share your thoughts about this mural..." required></textarea>
									<div class="valid-feedback">Looks good!</div>
								</div>
								<button type="submit" class="btn btn-primary w-100">
									<i class="fas fa-paper-plane"></i> Submit Review
								</button>
							</form>
						</div>
					</div>
					<% } %>

					<!-- Existing Reviews -->
					<% if(mural.reviews.length > 0) { %>
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">
								<i class="fas fa-comments"></i> Reviews 
								<span class="badge bg-secondary ms-2"><%= mural.reviews.length %></span>
							</h5>
						</div>
						<div class="card-body">
							<% for(let review of mural.reviews) { %>
							<div class="review-item <%= mural.reviews.indexOf(review) !== mural.reviews.length - 1 ? 'border-bottom' : '' %> pb-3 mb-3">
								<div class="d-flex justify-content-between align-items-start mb-2">
									<div>
										<h6 class="mb-1"><%= review.author.username%></h6>
										<p class="starability-result mb-0" data-rating="<%=review.rating%>">
											Rated: <%= review.rating %> stars
										</p>
									</div>
									<% if( currentUser && review.author.equals(currentUser._id)) {%>
									<form action="/murals/<%=mural._id%>/reviews/<%=review._id%>?_method=DELETE" method="POST" class="d-inline">
										<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this review?')">
											<i class="fas fa-trash-alt"></i>
										</button>
									</form>
									<% } %>
								</div>
								<p class="text-muted mb-0"><%= review.body %></p>
							</div>
							<% } %>
						</div>
					</div>
					<% } else { %>
					<div class="card">
						<div class="card-body text-center">
							<i class="fas fa-comments fa-3x text-muted mb-3"></i>
							<h6 class="text-muted">No reviews yet</h6>
							<p class="text-muted mb-0">Be the first to share your thoughts!</p>
						</div>
					</div>
					<% } %>
				</div>
			</div>
		</div>
	</div>

	<!-- Delete Confirmation Modal -->
	<% if( currentUser && mural.author.equals(currentUser._id)) {%>
	<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="deleteModalLabel">Delete Mural</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<p>Are you sure you want to delete "<strong><%= mural.title %></strong>"?</p>
					<p class="text-muted">This action cannot be undone.</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
					<form action="/murals/<%=mural._id%>?_method=DELETE" method="POST" class="d-inline">
						<button type="submit" class="btn btn-danger">Delete Mural</button>
					</form>
				</div>
			</div>
		</div>
	</div>
	<% } %>
</div>

<script>
	const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
	const mural = <%- JSON.stringify(mural) %>
</script>

<script src="/javascripts/showPageMap.js"></script>
