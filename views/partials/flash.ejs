<% if (typeof success !== 'undefined' && success && success.length) {
%>
<div
	class="bg-green-50 border-l-4 border-green-400 p-4 mb-6 rounded-lg shadow-sm animate-fadeInUp"
	role="alert">
	<div class="flex items-center justify-between">
		<div class="flex items-center">
			<i class="fas fa-check-circle text-green-400 mr-3"></i>
			<p class="text-green-800 font-medium"><%= success %></p>
		</div>
		<button
			type="button"
			class="text-green-400 hover:text-green-600 transition-colors"
			onclick="this.parentElement.parentElement.remove()"
			aria-label="Close">
			<i class="fas fa-times"></i>
		</button>
	</div>
</div>
<% } %> <% if (typeof error !== 'undefined' && error && error.length)
{ %>
<div
	class="bg-red-50 border-l-4 border-red-400 p-4 mb-6 rounded-lg shadow-sm animate-fadeInUp"
	role="alert">
	<div class="flex items-center justify-between">
		<div class="flex items-center">
			<i class="fas fa-exclamation-circle text-red-400 mr-3"></i>
			<p class="text-red-800 font-medium"><%= error %></p>
		</div>
		<button
			type="button"
			class="text-red-400 hover:text-red-600 transition-colors"
			onclick="this.parentElement.parentElement.remove()"
			aria-label="Close">
			<i class="fas fa-times"></i>
		</button>
	</div>
</div>
<% } %>
